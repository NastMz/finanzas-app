{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@finanzas/domain": [
        "packages/domain/src/index.ts"
      ],
      "@finanzas/application": [
        "packages/application/src/index.ts"
      ],
      "@finanzas/data/sqlite": [
        "packages/data/src/sqlite/index.ts"
      ],
      "@finanzas/data": [
        "packages/data/src/index.ts"
      ],
      "@finanzas/sync": [
        "packages/sync/src/index.ts"
      ],
      "@finanzas/ui": [
        "packages/ui/src/index.ts"
      ],
      "@finanzas/ui/design-system": [
        "packages/ui/src/design-system/index.ts"
      ],
      "@finanzas/platform-shared/sqlite": [
        "packages/platform/platform-shared/src/sqlite-context.ts"
      ],
      "@finanzas/platform-shared": [
        "packages/platform/platform-shared/src/index.ts"
      ],
      "@finanzas/platform-shared/testing": [
        "packages/platform/platform-shared/src/platform-wrapper-bootstrap-smoke.test-helper.ts"
      ]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.d.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/**/*.d.ts"
  ]
}
